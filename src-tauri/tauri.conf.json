{
  "$schema": "https://raw.githubusercontent.com/nicekid1/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Hoomestead Chat",
  "identifier": "com.hoomestead.chat",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Hoomestead Chat",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
