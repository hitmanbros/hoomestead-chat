{
  "name": "openclaw-client",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && concurrently \"vite\" \"electron .\"",
    "build": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "package": "npm run build && npm run build:electron && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "livekit-client": "^2.17.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "build": {
    "appId": "com.hoomestead.chat",
    "productName": "OpenClaw Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src-rust/target/release/hoomestead-chat-server",
        "to": "hoomestead-chat-server",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network;Chat"
    },
    "win": {
      "target": ["nsis"],
      "extraResources": [
        {
          "from": "src-rust/target/release/hoomestead-chat-server.exe",
          "to": "hoomestead-chat-server.exe"
        }
      ]
    }
  }
}
